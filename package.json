{
  "name": "lab1",
  "version": "1.0.0",
  "description": "Library fine calculator with CI/CD",
  "main": "server.js",
  "scripts": {
    "test": "jest",
    "test:unit": "jest",
    "test:api": "cucumber-js",
    "test:ui": "npx playwright test",
    "test:all": "npm run test:unit && npm run test:api && npm run test:ui",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "kill": "kill -9 $(lsof -ti :3000) 2>/dev/null || true"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "allure-commandline": "^2.29.0",
    "allure-cucumberjs": "^3.0.0",
    "allure-jest": "^3.0.0",
    "allure-playwright": "^3.7.1",
    "jest": "^30.2.0"
  },
  "dependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "express": "^5.2.1",
    "playwright": "^1.58.2",
    "supertest": "^7.2.2"
  }
}
